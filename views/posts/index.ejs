<!DOCTYPE html>
<html lang = "en">
<%- include('../includes/head', {title: 'Posts | Appreciation Wall'}) %>
<body>
    <%- include('../includes/header') %>
    

    <main>
        <p>Our appreciation posts: </p>
        <ul>
            <% posts.forEach(post => { %>
                <li>
                    <a href="/posts/<%= post.slug %>"><%= post.number %>. <%= post.name %> </a>
                </li>
            <% }) %>
        </ul>

        
        
    </main>

</body>



</html>